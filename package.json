{
  "name": "flatmarkdown-ast",
  "version": "0.2.0",
  "description": "TypeScript type definitions for the FlatMarkdown AST.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/petajournal/flatmarkdown-ast.git"
  },
  "bugs": {
    "url": "https://github.com/petajournal/flatmarkdown-ast/issues"
  },
  "homepage": "https://github.com/petajournal/flatmarkdown-ast#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "flatmarkdown",
    "ast",
    "markdown",
    "types",
    "typescript"
  ],
  "author": "Hidekazu Kubota",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
